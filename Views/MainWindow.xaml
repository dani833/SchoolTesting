<Window x:Class="SchoolTesting.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Школьный тестировщик" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Drag">
    <Window.Resources>
        <DropShadowEffect x:Key="Shadow" BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
    </Window.Resources>
    <Grid>
        <Border CornerRadius="15" Effect="{StaticResource Shadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8F9FA" Offset="0"/>
                    <GradientStop Color="#E9ECEF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📚 Школьный тестировщик" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,15,0,25"/>
                <TextBlock Grid.Row="1" Text="Логин" FontSize="13" Foreground="#6C757D" Margin="0,0,0,5"/>
                <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15">
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CleanTextBox}" Height="38" Padding="12,0"/>
                </Border>
                <TextBlock Grid.Row="3" Text="Пароль" FontSize="13" Foreground="#6C757D" Margin="0,0,0,5"/>
                <Border Grid.Row="4" Background="White" CornerRadius="8" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15">
                    <PasswordBox x:Name="PwdBox" PasswordChanged="PwdChanged" Style="{StaticResource CleanPasswordBox}" Height="38" Padding="12,0"/>
                </Border>
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <Button Content="👩‍🏫 Я учитель" Width="140" Height="42" Margin="5" Command="{Binding LoginTeacher}"
                            Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#3498DB" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#2980B9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#1F6A9A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🎓 Я ученик" Width="140" Height="42" Margin="5" Command="{Binding LoginStudent}"
                            Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#2ECC71" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#27AE60"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#1E8449"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}" Foreground="#E74C3C" HorizontalAlignment="Center" Margin="0,15"/>
                <Button Content="✕" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30"
                        Background="Transparent" Foreground="#6C757D" Click="CloseClick" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>