<Window x:Class="SchoolTesting.Views.TestEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор теста" Height="600" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Название:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,20,0"/>
            <TextBlock Grid.Column="2" Text="Предмет:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="3" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,20,0"/>
            <TextBlock Grid.Column="4" Text="Время (мин):" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="5" Text="{Binding Time, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,10">
            <Button Content="➕ Добавить вопрос" Width="140" Height="35" Margin="5" Background="#3498DB" Foreground="White" Command="{Binding Add}"/>
            <Button Content="✏️ Редактировать" Width="120" Height="35" Margin="5" Background="#F39C12" Foreground="White" Command="{Binding Edit}"/>
            <Button Content="🗑️ Удалить" Width="120" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Command="{Binding Delete}"/>
        </StackPanel>
        <ListBox Grid.Row="2" ItemsSource="{Binding Questions}" SelectedItem="{Binding Selected}" DisplayMemberPath="Text"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15">
            <Button Content="Сохранить" Width="100" Height="35" Margin="5" Background="#2ECC71" Foreground="White" Command="{Binding Save}"/>
            <Button Content="Отмена" Width="100" Height="35" Margin="5" Background="#95A5A6" Foreground="White" Command="{Binding Cancel}"/>
        </StackPanel>
    </Grid>
</Window>