<Window x:Class="SchoolTesting.Views.TestExecutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SchoolTesting.ViewModels"
        Title="Прохождение теста" Height="550" Width="800"
        WindowStartupLocation="CenterOwner" WindowState="Maximized" WindowStyle="None" AllowsTransparency="False">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <Grid>
                <TextBlock Text="{Binding TestTitle}" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Оставшееся время:" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding RemainingTime}" Foreground="{Binding TimerColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Width="100" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{Binding ProgressText}" FontSize="14" Foreground="Gray"/>
                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Height="10" Margin="0,5"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#F8F9FA" Padding="20" CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentQuestionText}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <ContentControl Content="{Binding CurrentQuestionViewModel}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type vm:MultipleChoiceQuestionVM}">
                                    <ItemsControl ItemsSource="{Binding Options}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <RadioButton GroupName="Answer" Margin="5" FontSize="14"
                                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                             Content="{Binding Text}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type vm:TextInputQuestionVM}">
                                    <TextBox Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Margin="5"/>
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type vm:NumberInputQuestionVM}">
                                    <TextBox Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Margin="5"/>
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="◀ Назад" Width="120" Height="40" Margin="5"
                        Command="{Binding PreviousCommand}" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Далее ▶" Width="120" Height="40" Margin="5"
                        Command="{Binding NextCommand}" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Завершить тест" Width="150" Height="40" Margin="5"
                        Command="{Binding FinishCommand}" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#ECF0F1" Padding="10">
            <TextBlock Text="Используйте кнопки для навигации. Ответы сохраняются автоматически." Foreground="Gray"/>
        </Border>
    </Grid>
</Window>
