<Window x:Class="SchoolTesting.Views.StudentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ученик" Height="500" Width="700" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <TextBlock Text="Доступные тесты" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Выход" Width="80" Height="30" Background="#E74C3C" Foreground="White" Command="{Binding Logout}"/>
                </StackPanel>
            </Grid>
        </Border>
        <ListBox Grid.Row="1" ItemsSource="{Binding Tests}" SelectedItem="{Binding Selected}" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Subject}" Foreground="Gray"/>
                            <TextBlock Text="{Binding TimeLimitMinutes, StringFormat='Время: {0} мин.'}" Foreground="Gray"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding MaxScore, StringFormat='Баллы: {0}'}" VerticalAlignment="Center" Margin="10,0"/>
                        <Button Grid.Column="2" Content="Начать" Width="100" Height="30" Background="#2ECC71" Foreground="White"
                                Command="{Binding DataContext.Start, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>