<Window x:Class="SchoolTesting.Views.TeacherMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учитель" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <TextBlock Text="Панель учителя" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Выход" Width="80" Height="30" Background="#E74C3C" Foreground="White" Command="{Binding Logout}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="📋 Тесты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Создать" Width="120" Height="35" Margin="5" Background="#3498DB" Foreground="White" Command="{Binding Create}"/>
                        <Button Content="✏️ Редактировать" Width="120" Height="35" Margin="5" Background="#F39C12" Foreground="White" Command="{Binding Edit}"/>
                        <Button Content="🗑️ Удалить" Width="120" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Command="{Binding Delete}"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Tests}" SelectedItem="{Binding Selected}" DisplayMemberPath="Title"/>
                </Grid>
            </TabItem>

            <TabItem Header="📊 Статистика">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Статистика успеваемости" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Ученик:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}" DisplayMemberPath="FullName" Width="200"/>
                        <Button Content="Обновить" Width="80" Margin="10,0,0,0" Command="{Binding RefreshStatisticsCommand}"/>
                        <Button Content="Экспорт в Excel" Width="120" Margin="10,0,0,0" Command="{Binding ExportExcelCommand}"/>
                        <Button Content="Экспорт в PDF" Width="120" Margin="10,0,0,0" Command="{Binding ExportPdfCommand}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding StatisticsResults}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="120"/>
                            <DataGridTextColumn Header="Тест" Binding="{Binding TestTitle}" Width="200"/>
                            <DataGridTextColumn Header="Набрано баллов" Binding="{Binding ScoreEarned}" Width="100"/>
                            <DataGridTextColumn Header="Макс. баллов" Binding="{Binding MaxScore}" Width="100"/>
                            <DataGridTextColumn Header="Процент" Binding="{Binding Percentage, StringFormat='F1'}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>