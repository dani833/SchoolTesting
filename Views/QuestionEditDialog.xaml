<Window x:Class="SchoolTesting.Views.QuestionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SchoolTesting.Helpers"
        Title="Редактирование вопроса" Height="450" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <!-- Остальное содержимое без изменений -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Тип вопроса:" Width="100" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding QuestionTypes}" SelectedItem="{Binding SelectedType}" Width="200"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Текст вопроса:" Margin="0,5"/>
        <TextBox Grid.Row="2" Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}" 
                 TextWrapping="Wrap" Height="60" Margin="0,0,0,10" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <Grid Grid.Row="3" Visibility="{Binding IsMultipleChoice, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Варианты ответов:" FontWeight="Bold" Margin="0,5"/>
            <ScrollViewer Grid.Row="1" MaxHeight="150" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Options}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton GroupName="CorrectAnswer" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Margin="5,0"/>
                                <Button Grid.Column="2" Content="✕" Width="25" Height="25" 
                                        Command="{Binding DataContext.RemoveOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Foreground="Red" Cursor="Hand"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Button Grid.Row="2" Content="➕ Добавить вариант" Width="140" Height="30" Margin="0,5"
                    Command="{Binding AddOptionCommand}" HorizontalAlignment="Left"/>
        </Grid>

        <StackPanel Grid.Row="3" Visibility="{Binding IsTextInput, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Правильный ответ:" FontWeight="Bold" Margin="0,5"/>
            <TextBox Text="{Binding CorrectAnswer, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Visibility="{Binding IsNumberInput, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Правильное число:" FontWeight="Bold" Margin="0,5"/>
            <TextBox Text="{Binding CorrectValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
            <TextBlock Text="Допустимая погрешность:" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBox Text="{Binding Tolerance, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Баллы за вопрос:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,10,0"
                    Command="{Binding OkCommand}" IsDefault="True"/>
            <Button Content="Отмена" Width="80" Height="30"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>